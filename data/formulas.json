{
  "dot_duration_player": {
    "Bleed_Duration_Final": {
      "formula": "7 + (7 * Bleed_Duration_Mod_Bonus)"
    },
    "Burn_Duration_Final": {
      "formula": "5 + (5 * Burn_Duration_Mod_Bonus)"
    },
    "Poison_Duration_Final": {
      "formula": "4 + (4 * Poison_Duration_Mod_Bonus)"
    },
    "Poison_RedPowder_Duration_Final": {
      "formula": "3.5 + (3.5 * Poison_Duration_Mod_Bonus)"
    },
    "Disrupt_Duration_Final": {
      "formula": "10 + (10 * Disrupt_Duration_Mod_Bonus)"
    },
    "Shock_Duration_Final": {
      "formula": "3 + (3 * Shock_Duration_Mod_Bonus)"
    },
    "Blind_Duration_Final": {
      "formula": "5 + (5 * Blind_Duration_Mod_Bonus)"
    },
    "Ensnare_Duration_Final": {
      "formula": "7 + (7 * Ensnare_Duration_Mod_Bonus)"
    },
    "Ensnare_Napalm_Duration_Final": {
      "formula": "4.5 + (4.5 * Ensnare_Duration_Mod_Bonus)"
    },
    "Confuse_Duration_Final": {
      "formula": "7 + (7 * Confuse_Duration_Mod_Bonus)"
    }
  },
  "dot_duration_npc": {
    "NPC_Bleed_Duration_Base": {
      "formula": "10 + (10 * Bleed_Duration_Mod_Bonus)"
    },
    "NPC_Burn_Duration_Base": {
      "formula": "7 + (7 * Burn_Duration_Mod_Bonus)"
    },
    "NPC_GreekFire_Duration_Base": {
      "formula": "8 + (8 * Burn_Duration_Mod_Bonus)"
    },
    "NPC_Poison_Duration_Base": {
      "formula": "10 + (10 * Poison_Duration_Mod_Bonus)"
    },
    "NPC_Disrupt_Duration_Base": {
      "formula": "15 + (15 * Disrupt_Duration_Mod_Bonus)"
    },
    "NPC_Shock_Duration_Base": {
      "formula": "5 + (5 * Shock_Duration_Mod_Bonus)"
    },
    "NPC_Blind_Duration_Base": {
      "formula": "7 + (7 * Blind_Duration_Mod_Bonus)"
    },
    "NPC_Ensnare_Duration_Base": {
      "formula": "7 + (7 * Ensnare_Duration_Mod_Bonus)"
    },
    "NPC_Ensnare_Napalm_Duration_Base": {
      "formula": "7 + (7 * Ensnare_Duration_Mod_Bonus)"
    },
    "NPC_Confuse_Duration_Base": {
      "formula": "10 + (10 * Confuse_Duration_Mod_Bonus)"
    }
  },
  "armor_mitigation": {
    "ArmorMitigationRatingFinal": {
      "formula": "Max(0, (ArmorMitigationDefaultRatingFlatBonus + ArmorMitigationRatingFlatBonus) * (1 + ArmorMitigationRatingModBonus))"
    },
    "ArmorMitigationPercentageCalc": {
      "formula": "Min(0.70, ((ArmorMitigationRatingFinal / (ArmorMitigationRatingScalarCalc * ArmorMitigationRatingDivisorCalc)) + ArmorMitigationPercentageFlatBonus) * Max(0, (1 + ArmorMitigationPercentageModBonus)))"
    },
    "ArmorMitigationRatingScalarCalc": {
      "formula": "1.1 ^ Max(0, (agent.level - 1))"
    }
  },
  "ammo_by_weapon_type": {
    "AssaultRifleAmmoFinal": {
      "formula": "Max(0,(810 + AllAmmoFlatBonus + AssaultRifleAmmoFlatBonus) * (1 + AllAmmoModBonus + AssaultRifleAmmoModBonus))"
    },
    "LMGAmmoFinal": {
      "formula": "Max(0,(900 + AllAmmoFlatBonus + LMGAmmoFlatBonus) * (1 + AllAmmoModBonus + LMGAmmoModBonus))"
    },
    "MarksmanRifleAmmoFinal": {
      "formula": "Max(0,(120 + AllAmmoFlatBonus + MarksmanRifleAmmoFlatBonus) * (1 + AllAmmoModBonus + MarksmanRifleAmmoModBonus))"
    },
    "PistolAmmoFinal": {
      "formula": "Max(0,(AllAmmoFlatBonus + PistolAmmoFlatBonus) * (1 + AllAmmoModBonus + PistolAmmoModBonus))"
    },
    "ShotgunAmmoFinal": {
      "formula": "Max(0,(144 + AllAmmoFlatBonus + ShotgunAmmoFlatBonus) * (1 + AllAmmoModBonus + ShotgunAmmoModBonus))"
    },
    "SMGAmmoFinal": {
      "formula": "Max(0,(900 + AllAmmoFlatBonus + SMGAmmoFlatBonus) * (1 + AllAmmoModBonus + SMGAmmoModBonus))"
    },
    "RifleAmmoFinal": {
      "formula": "(420 + AllAmmoFlatBonus + RifleAmmoFlatBonus) * (1 + AllAmmoModBonus + RifleAmmoModBonus)"
    }
  },
  "skill": {
    "SkillHasteFinal": {
      "formula": "MIN(SkillHasteCap, SkillHasteModFinal)"
    },
    "SkillPowerFinal": {
      "formula": "Min(Min(SkillPowerFlatBonus,6) + SkillPowerOverchargeFlatBonus,7)"
    },
    "SkillPowerChemLauncherFinal": {
      "formula": "Min(Min((SkillPowerFlatBonus + SkillPowerChemLauncherFlatBonus),6)+SkillPowerOverchargeFlatBonus,7)"
    },
    "SkillPowerDroneFinal": {
      "formula": "Min(Min((SkillPowerFlatBonus + SkillPowerDroneFlatBonus),6)+SkillPowerOverchargeFlatBonus+SkillPowerOverchargeDroneTacticianFlatBonus,7)"
    },
    "SkillPowerFireflyFinal": {
      "formula": "Min(Min((SkillPowerFlatBonus + SkillPowerFireflyFlatBonus),6)+SkillPowerOverchargeFlatBonus,7)"
    },
    "SkillPowerHiveFinal": {
      "formula": "Min(Min((SkillPowerFlatBonus + SkillPowerHiveFlatBonus),6)+SkillPowerOverchargeFlatBonus+SkillPowerOverchargeHiveArtificerFlatBonus,7)"
    },
    "SkillPowerPulseFinal": {
      "formula": "Min(Min((SkillPowerFlatBonus + SkillPowerPulseFlatBonus),6)+SkillPowerOverchargeFlatBonus+SkillPowerOverchargePulseBansheeFlatBonus,7)"
    },
    "SkillPowerSeekerFinal": {
      "formula": "Min(Min((SkillPowerFlatBonus + SkillPowerSeekerFlatBonus),6)+SkillPowerOverchargeFlatBonus+SkillPowerOverchargeSeekerMineMenderFlatBonus,7)"
    },
    "SkillPowerShieldFinal": {
      "formula": "Min(Min((SkillPowerFlatBonus + SkillPowerShieldFlatBonus + Gear.NumberCoreDefensiveAttributes),6)+SkillPowerOverchargeFlatBonus+SkillPowerOverchargeShieldStrikerFlatBonus,7)"
    },
    "SkillPowerTurretFinal": {
      "formula": "Min(Min((SkillPowerFlatBonus + SkillPowerTurretFlatBonus),6)+SkillPowerOverchargeFlatBonus+SkillPowerOverchargeTurretArtilleryModFlatBonus,7)"
    },
    "SkillPowerStickyFinal": {
      "formula": "Min(Min((SkillPowerFlatBonus + SkillPowerStickyFlatBonus),6)+SkillPowerOverchargeFlatBonus,7)"
    },
    "SkillPowerTrapFinal": {
      "formula": "Min(Min((SkillPowerFlatBonus + SkillPowerTrapFlatBonus),6)+SkillPowerOverchargeFlatBonus,7)"
    },
    "SkillPowerDecoyFinal": {
      "formula": "Min(Min((SkillPowerFlatBonus + SkillPowerDecoyFlatBonus),6)+SkillPowerOverchargeFlatBonus,7)"
    },
    "SkillPowerSmartCoverFinal": {
      "formula": "Min(Min((SkillPowerFlatBonus + SkillPowerSmartCoverFlatBonus),6)+SkillPowerOverchargeFlatBonus,7)"
    }
  },
  "health_armor": {
    "BleedingOutHealthDegenTickIntervalPvPFinal": {
      "formula": "BleedingOutHealthPvPFinal * -0.1"
    },
    "BleedingOutHealthDegenRateFinal": {
      "formula": "BleedingOutHealthFinal * -0.1"
    },
    "DownedHealthFinal": {
      "formula": "HealthFinal * 0.5"
    },
    "DownedHealthPvPFinal": {
      "formula": "HealthFinal * 0.5"
    },
    "DownedHealthDegenRateFinal": {
      "formula": "DownedHealthFinal * -0.02222"
    },
    "DownedHealthDegenRatePvPFinal": {
      "formula": "DownedHealthPvPFinal * -0.02222"
    },
    "HealthFinal": {
      "formula": "Max(0, (PrimaryDefensiveCalc +PlayerHealthCalc+ HealthFlatBonus)) * Max(0, (1 + HealthModBonus))"
    },
    "HealthPercentageCalc": {
      "formula": "Agent.CurrentHealth / HealthFinal"
    },
    "HealthSegmentsFinal": {
      "formula": "3 + HealthSegmentsFlatBonus"
    },
    "HealthRegenDelayFinal": {
      "formula": "6 * 1/(1 + HealthRegenDelayModBonus)"
    },
    "HealthRegenPerSecondCalc": {
      "formula": "HealthRegenRateFinal / HealthRegenTickIntervalFinal"
    },
    "PlayerArmorFinal": {
      "formula": "Max(0, (ArmorFlatBonus + ArmorGearFlatBonus)) * Max(0, (1 + ArmorModBonus)) * ArmorModDirectiveFragileArmor"
    },
    "ArmorPipCapacity": {
      "formula": "Max( 1, (Agent.ExpectedArmorAtCurrentLevel * 1.25) / 10)"
    },
    "ArmorCombatRegenRateFinal": {
      "formula": "ArmorRegenFlatBonus + (PlayerArmorFinal * ArmorRegenFlatBonusModBonus)"
    },
    "ArmorRegenDelayFinal": {
      "formula": "6 * 1/(1 + HealthRegenDelayModBonus)"
    },
    "ArmorOnKillFinal": {
      "formula": "(PlayerArmorFinal * ArmorOnKillModBonus) + ArmorOnKillFlatBonus"
    },
    "NPCArmorFinal": {
      "formula": "NPCArmorBase * NPCArmorScalingCalc * NPCRoleArmorScalingCalc"
    },
    "NPCArmorDamageModifierFinal": {
      "formula": "1 + NPCArmorDamageModifierBonus + NPCArmorDamageModifierDefaultBonus + NPCArmorDamageModifierGearModBonus + DamageDoneToArmorModBonus"
    },
    "DamageToPlayerArmorModFinal": {
      "formula": "Max(0, (1 + DamageDoneToArmorModBonus))"
    },
    "DamageToHealthModFinal": {
      "formula": "Max(0, (1 + DamageDoneToHealthModBonus))"
    },
    "EnsnareFoamHealthFinal": {
      "formula": "BaseCurve * 1500"
    }
  },
  "resistance_dot": {
    "BleedingStatusResistancePercentageFinal": {
      "formula": "MIN(1, BleedingStatusResistancePercentageFlatBonus + AllStatusResistancePercentageFinal)"
    },
    "BlindDeafStatusResistancePercentageFinal": {
      "formula": "MIN(1, BlindDeafStatusResistancePercentageFlatBonus + AllStatusResistancePercentageFinal)"
    },
    "BurningStatusResistancePercentageFinal": {
      "formula": "MIN(1, BurningStatusResistancePercentageFlatBonus + AllStatusResistancePercentageFinal)"
    },
    "ConfusedStatusResistancePercentageFinal": {
      "formula": "MIN(1, ConfusedStatusResistancePercentageFlatBonus + AllStatusResistancePercentageFinal)"
    },
    "DisruptedStatusResistancePercentageFinal": {
      "formula": "MIN(1, DisruptedStatusResistancePercentageFlatBonus + AllStatusResistancePercentageFinal)"
    },
    "ShockedStatusResistancePercentageFinal": {
      "formula": "MIN(1, ShockedStatusResistancePercentageFlatBonus + AllStatusResistancePercentageFinal)"
    },
    "StaggeredStatusResistancePercentageFinal": {
      "formula": "MIN(1, StaggeredStatusResistancePercentageFlatBonus + AllStatusResistancePercentageFinal)"
    },
    "SuppressedStatusResistancePercentageFinal": {
      "formula": "MIN(1, SuppressedStatusResistancePercentageFlatBonus + AllStatusResistancePercentageFinal)"
    },
    "EnsnaredStatusResistancePercentageFinal": {
      "formula": "MIN(1, EnsnaredStatusResistancePercentageFlatBonus + AllStatusResistancePercentageFinal)"
    },
    "PoisonStatusResistancePercentageFinal": {
      "formula": "MIN(1, PoisonStatusResistancePercentageFlatBonus + AllStatusResistancePercentageFlatBonus + AllStatusResistancePercentageGearmodFlatBonus + TalentAllStatusResistancePercentageFlatBonus)"
    },
    "AllStatusResistancePercentageFinal": {
      "formula": "AllStatusResistancePercentageFlatBonus + AllStatusResistancePercentageGearmodFlatBonus + TalentAllStatusResistancePercentageFlatBonus"
    },
    "SkillPulseResistancePercentageFinal": {
      "formula": "MIN( 1, PulseResistancePercentageFlatBonus )"
    }
  },
  "damage_mitigation_type": {
    "SkillMethodDamageMitigationPercentageFinal": {
      "formula": "Min(0.95, ((SkillMethodDamageMitigationRatingFinal / 1000) + AllMethodDamageMitigationPercentageFlatBonus + SkillMethodDamageMitigationPercentageFlatBonus) * Max(0, (1 + AllMethodDamageMitigationPercentageModBonus + SkillMethodDamageMitigationPercentageModBonus)))"
    },
    "StatusEffectMethodDamageMitigationPercentageFinal": {
      "formula": "Min(0.95, ((StatusEffectDamageMethodMitigationRatingFinal / 1000) + AllMethodDamageMitigationPercentageFlatBonus + StatusEffectMethodDamageMitigationPercentageFlatBonus) * Max(0, (1 + AllMethodDamageMitigationPercentageModBonus + StatusEffectMethodDamageMitigationPercentageModBonus)))"
    },
    "TrapMethodDamageMitigationPercentageFinal": {
      "formula": "Min(0.95, ((TrapMethodDamageMitigationRatingFinal / 1000) + AllMethodDamageMitigationPercentageFlatBonus + TrapMethodDamageMitigationPercentageFlatBonus) * Max(0, (1 + AllMethodDamageMitigationPercentageModBonus + TrapMethodDamageMitigationPercentageModBonus)))"
    },
    "WeaponMethodDamageMitigationPercentageFinal": {
      "formula": "Min(0.95, ((WeaponMethodDamageMitigationRatingFinal / 1000) + AllMethodDamageMitigationPercentageFlatBonus + WeaponMethodDamageMitigationPercentageFlatBonus) * Max(0, (1 + AllMethodDamageMitigationPercentageModBonus + WeaponMethodDamageMitigationPercentageModBonus)))"
    },
    "BlastDamageMitigationPercentageFinal": {
      "formula": "MIN(0.9, ExoticDamageMitigationPercentageFlatBonus + AllDamageMitigationPercentageFlatBonus + BlastDamageMitigationPercentageFlatBonus)"
    },
    "BleedDamageMitigationPercentageFinal": {
      "formula": "MIN(0.9, ExoticDamageMitigationPercentageFlatBonus + AllDamageMitigationPercentageFlatBonus + BleedDamageMitigationPercentageFlatBonus)"
    },
    "BurnDamageMitigationPercentageFinal": {
      "formula": "MIN(0.9, ExoticDamageMitigationPercentageFlatBonus + AllDamageMitigationPercentageFlatBonus + BurnDamageMitigationPercentageFlatBonus)"
    },
    "ElectricDamageMitigationPercentageFinal": {
      "formula": "MIN(0.9, ExoticDamageMitigationPercentageFlatBonus + AllDamageMitigationPercentageFlatBonus + ElectricDamageMitigationPercentageFlatBonus)"
    },
    "EMPDamageMitigationPercentageFinal": {
      "formula": "MIN(1, ExoticDamageMitigationPercentageFlatBonus + AllDamageMitigationPercentageFlatBonus + EMPDamageMitigationPercentageFlatBonus)"
    },
    "PhysicalDamageMitigationPercentageFinal": {
      "formula": "MIN(0.9, ArmorMitigationPercentageCalc + AllDamageMitigationPercentageFlatBonus + PhysicalDamageMitigationPercentageFlatBonus)"
    },
    "ToxinDamageMitigationPercentageFinal": {
      "formula": "MIN(0.9, ExoticDamageMitigationPercentageFlatBonus + AllDamageMitigationPercentageFlatBonus + ToxinDamageMitigationPercentageFlatBonus)"
    },
    "FriendlySourceDamageMitigationPercentageFinal": {
      "formula": "Min(0.95, ((FriendlySourceDamageMitigationRatingFinal / 1000) + AllSourceDamageMitigationPercentageFlatBonus + FriendlySourceDamageMitigationPercentageFlatBonus) * Max(0, (1 + AllSourceDamageMitigationPercentageModBonus + FriendlySourceDamageMitigationPercentageModBonus)))"
    },
    "NPCSourceDamageMitigationPercentageFinal": {
      "formula": "Min(0.95, ((NPCSourceDamageMitigationRatingFinal / 1000) + AllSourceDamageMitigationPercentageFlatBonus + NPCSourceDamageMitigationPercentageFlatBonus) * Max(0, (1 + AllSourceDamageMitigationPercentageModBonus + NPCSourceDamageMitigationPercentageModBonus)))"
    },
    "NullSourceDamageMitigationPercentageFinal": {
      "formula": "Min(0.95, ((NullSourceDamageMitigationRatingFinal / 1000) + AllSourceDamageMitigationPercentageFlatBonus + NullSourceDamageMitigationPercentageFlatBonus) * Max(0, (1 + AllSourceDamageMitigationPercentageModBonus + NullSourceDamageMitigationPercentageModBonus)))"
    },
    "OpponentSourceDamageMitigationPercentageFinal": {
      "formula": "Min(0.95, ((OpponentSourceDamageMitigationRatingFinal / 1000) + AllSourceDamageMitigationPercentageFlatBonus + OpponentSourceDamageMitigationPercentageFlatBonus) * Max(0, (1 + AllSourceDamageMitigationPercentageModBonus + OpponentSourceDamageMitigationPercentageModBonus)))"
    },
    "SelfSourceDamageMitigationPercentageFinal": {
      "formula": "Min(0.95, ((SelfSourceDamageMitigationRatingFinal / 1000) + AllSourceDamageMitigationPercentageFlatBonus + SelfSourceDamageMitigationPercentageFlatBonus) * Max(0, (1 + AllSourceDamageMitigationPercentageModBonus + SelfSourceDamageMitigationPercentageModBonus)))"
    }
  },
  "crit": {
    "CriticalHitChanceResilienceFinal": {
      "formula": "Min(Max(1 - CriticalHitChanceResilienceFlatBonus,0),1)"
    }
  },
  "all": {
    "PrimaryDefensiveFinal": {
      "formula": "PrimaryDefensiveBase + PrimaryDefensiveDefaultBaseFlatBonus + PrimaryDefensiveDefaultFlatBonus + PrimaryDefensiveFlatBonus"
    },
    "PrimaryOffensiveFinal": {
      "formula": "PrimaryOffensiveBase + PrimaryOffensiveDefaultBaseFlatBonus + PrimaryOffensiveDefaultFlatBonus + PrimaryOffensiveFlatBonus"
    },
    "PrimarySupportFinal": {
      "formula": "PrimarySupportBase + PrimarySupportDefaultBaseFlatBonus + PrimarySupportDefaultFlatBonus + PrimarySupportFlatBonus"
    },
    "PrimaryDefensiveCalc": {
      "formula": "PrimaryDefensiveFinal * 30"
    },
    "PrimaryOffensiveCalc": {
      "formula": "PrimaryOffensiveFinal * 0.01"
    },
    "PrimarySupportCalc": {
      "formula": "PrimarySupportFinal * ElectronicsToSkillPowerConversionRate"
    },
    "AirSupplyRegenRateFinal": {
      "formula": "AirSupplyFinal * 0.1"
    },
    "ContaminationZoneGasMaskLevelFinal": {
      "formula": "ContaminationZone.GasMaskLevel + ContaminationZoneGasMaskLevelDefaultFlatBonus + ContaminationZoneGasMaskLevelFlatBonus"
    },
    "SkillMethodDamageMitigationPercentageFinal": {
      "formula": "Min(0.95, ((SkillMethodDamageMitigationRatingFinal / 1000) + AllMethodDamageMitigationPercentageFlatBonus + SkillMethodDamageMitigationPercentageFlatBonus) * Max(0, (1 + AllMethodDamageMitigationPercentageModBonus + SkillMethodDamageMitigationPercentageModBonus)))"
    },
    "StatusEffectMethodDamageMitigationPercentageFinal": {
      "formula": "Min(0.95, ((StatusEffectDamageMethodMitigationRatingFinal / 1000) + AllMethodDamageMitigationPercentageFlatBonus + StatusEffectMethodDamageMitigationPercentageFlatBonus) * Max(0, (1 + AllMethodDamageMitigationPercentageModBonus + StatusEffectMethodDamageMitigationPercentageModBonus)))"
    },
    "TrapMethodDamageMitigationPercentageFinal": {
      "formula": "Min(0.95, ((TrapMethodDamageMitigationRatingFinal / 1000) + AllMethodDamageMitigationPercentageFlatBonus + TrapMethodDamageMitigationPercentageFlatBonus) * Max(0, (1 + AllMethodDamageMitigationPercentageModBonus + TrapMethodDamageMitigationPercentageModBonus)))"
    },
    "WeaponMethodDamageMitigationPercentageFinal": {
      "formula": "Min(0.95, ((WeaponMethodDamageMitigationRatingFinal / 1000) + AllMethodDamageMitigationPercentageFlatBonus + WeaponMethodDamageMitigationPercentageFlatBonus) * Max(0, (1 + AllMethodDamageMitigationPercentageModBonus + WeaponMethodDamageMitigationPercentageModBonus)))"
    },
    "EnvironmentMethodDamageMitigationRatingFinal": {
      "formula": "Max(0, (AllMethodDamageMitigationRatingFlatBonus + EnvironmentMethodDamageMitigationRatingFlatBonus)) * Max(0, (1 + AllMethodDamageMitigationRatingModBonus + EnvironmentMethodDamageMitigationRatingModBonus))"
    },
    "SkillMethodDamageMitigationRatingFinal": {
      "formula": "Max(0, (AllMethodDamageMitigationRatingFlatBonus + SkillMethodDamageMitigationRatingFlatBonus)) * Max(0, (1 + AllMethodDamageMitigationRatingModBonus + SkillMethodDamageMitigationRatingModBonus))"
    },
    "StatusEffectDamageMethodMitigationRatingFinal": {
      "formula": "Max(0, (AllMethodDamageMitigationRatingFlatBonus + StatusEffectMethodDamageMitigationRatingFlatBonus)) * Max(0, (1 + AllMethodDamageMitigationRatingModBonus + StatusEffectMethodDamageMitigationRatingModBonus))"
    },
    "TrapMethodDamageMitigationRatingFinal": {
      "formula": "Max(0, (AllMethodDamageMitigationRatingFlatBonus + TrapMethodDamageMitigationRatingFlatBonus)) * Max(0, (1 + AllMethodDamageMitigationRatingModBonus + TrapMethodDamageMitigationRatingModBonus))"
    },
    "WeaponMethodDamageMitigationRatingFinal": {
      "formula": "Max(0, (AllMethodDamageMitigationRatingFlatBonus + WeaponMethodDamageMitigationRatingFlatBonus)) * Max(0, (1 + AllMethodDamageMitigationRatingModBonus + WeaponMethodDamageMitigationRatingModBonus))"
    },
    "MovementSpeedModFinal": {
      "formula": "Max(Max(0, 1 + MovementSpeedModBonus), Min(1, MovementSpeedDebuffImmunity))"
    },
    "BlastDamageMitigationPercentageFinal": {
      "formula": "MIN(0.9, ExoticDamageMitigationPercentageFlatBonus + AllDamageMitigationPercentageFlatBonus + BlastDamageMitigationPercentageFlatBonus)"
    },
    "BleedDamageMitigationPercentageFinal": {
      "formula": "MIN(0.9, ExoticDamageMitigationPercentageFlatBonus + AllDamageMitigationPercentageFlatBonus + BleedDamageMitigationPercentageFlatBonus)"
    },
    "BurnDamageMitigationPercentageFinal": {
      "formula": "MIN(0.9, ExoticDamageMitigationPercentageFlatBonus + AllDamageMitigationPercentageFlatBonus + BurnDamageMitigationPercentageFlatBonus)"
    },
    "ElectricDamageMitigationPercentageFinal": {
      "formula": "MIN(0.9, ExoticDamageMitigationPercentageFlatBonus + AllDamageMitigationPercentageFlatBonus + ElectricDamageMitigationPercentageFlatBonus)"
    },
    "EMPDamageMitigationPercentageFinal": {
      "formula": "MIN(1, ExoticDamageMitigationPercentageFlatBonus + AllDamageMitigationPercentageFlatBonus + EMPDamageMitigationPercentageFlatBonus)"
    },
    "PhysicalDamageMitigationPercentageFinal": {
      "formula": "MIN(0.9, ArmorMitigationPercentageCalc + AllDamageMitigationPercentageFlatBonus + PhysicalDamageMitigationPercentageFlatBonus)"
    },
    "ToxinDamageMitigationPercentageFinal": {
      "formula": "MIN(0.9, ExoticDamageMitigationPercentageFlatBonus + AllDamageMitigationPercentageFlatBonus + ToxinDamageMitigationPercentageFlatBonus)"
    },
    "BlastDamageMitigationRatingFinal": {
      "formula": "Max(0, (AllDamageMitigationRatingFlatBonus + BlastDamageMitigationRatingFlatBonus)) * Max(0, (1 + AllDamageMitigationRatingModBonus + BlastDamageMitigationRatingModBonus))"
    },
    "BleedDamageMitigationRatingFinal": {
      "formula": "Max(0, (AllDamageMitigationRatingFlatBonus + BleedDamageMitigationRatingFlatBonus)) * Max(0, (1 + AllDamageMitigationRatingModBonus + BleedDamageMitigationRatingModBonus))"
    },
    "BurnDamageMitigationRatingFinal": {
      "formula": "Max(0, (AllDamageMitigationRatingFlatBonus + BurnDamageMitigationRatingFlatBonus)) * Max(0, (1 + AllDamageMitigationRatingModBonus + BurnDamageMitigationRatingModBonus))"
    },
    "ElectricDamageMitigationRatingFinal": {
      "formula": "Max(0, (AllDamageMitigationRatingFlatBonus + ElectricDamageMitigationRatingFlatBonus)) * Max(0, (1 + AllDamageMitigationRatingModBonus + ElectricDamageMitigationRatingModBonus))"
    },
    "EMPDamageMitigationRatingFinal": {
      "formula": "Max(0, (AllDamageMitigationRatingFlatBonus + EMPDamageMitigationRatingFlatBonus)) * Max(0, (1 + AllDamageMitigationRatingModBonus + EMPDamageMitigationRatingModBonus))"
    },
    "NeutralDamageMitigationRatingFinal": {
      "formula": "NeutralDamageMitigationRatingFlatBonus * Max(0, (1 + NeutralDamageMitigationRatingModBonus))"
    },
    "PhysicalDamageMitigationRatingFinal": {
      "formula": "Max(0, (AllDamageMitigationRatingFlatBonus + PhysicalDamageMitigationRatingFlatBonus)) * Max(0, (1 + AllDamageMitigationRatingModBonus + PhysicalDamageMitigationRatingModBonus))"
    },
    "StaminaDamageMitigationRatingFinal": {
      "formula": "Max(0, (AllDamageMitigationRatingFlatBonus + StaminaDamageMitigationRatingFlatBonus)) * Max(0, (1 + AllDamageMitigationRatingModBonus + StaminaDamageMitigationRatingModBonus))"
    },
    "ToxinDamageMitigationRatingFinal": {
      "formula": "Max(0, (AllDamageMitigationRatingFlatBonus + ToxinDamageMitigationRatingFlatBonus)) * Max(0, (1 + AllDamageMitigationRatingModBonus + ToxinDamageMitigationRatingModBonus))"
    },
    "DamageTypeRatingScalarCalc": {
      "formula": "1.115 ^ Max(0, (agent.level - 1))"
    },
    "FriendlySourceDamageMitigationPercentageFinal": {
      "formula": "Min(0.95, ((FriendlySourceDamageMitigationRatingFinal / 1000) + AllSourceDamageMitigationPercentageFlatBonus + FriendlySourceDamageMitigationPercentageFlatBonus) * Max(0, (1 + AllSourceDamageMitigationPercentageModBonus + FriendlySourceDamageMitigationPercentageModBonus)))"
