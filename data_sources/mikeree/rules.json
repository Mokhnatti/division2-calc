{
  "replaceRules": {
    "merica_armor": ["armour", "armor"],
    "number": ["[^0-9.]", ""],
    "Remove N/A": ["N/A", ""],
    "plus": ["\\+", ""],
    ">+1<": [">\\+1<\\s+", ""],
    "AlphaNumeric": ["[^a-zA-Z ]", ""],
    "#% key": ["(\\d+)%\\s+(.*)", "$2=$1"],
    "NoPlus": ["\\+", ""],
    "----": ["----", ""],
    "stat ##%": ["^([a-z\\s]+).*?([\\d.]+)%", "$1=$2"],
    "Any Basic (cant be HSD)": [
      "Any Basic\\s+\\(cant be HSD\\)",
      "damage to armor=6,critical hit chance=9.5,health damage=9.5,dmg to target out of cover=10,critical hit damage=10,reload speed=12,stability=12,accuracy=12,optimal range=24,magazine size=12.5,rate of fire=5,swap speed=15"
    ],
    "Any Basic": [
      "Any Basic",
      "damage to armor=6,critical hit chance=9.5,health damage=9.5,dmg to target out of cover=10,headshot damage=10,critical hit damage=10,reload speed=12,stability=12,accuracy=12,optimal range=24,magazine size=12.5,rate of fire=5,swap speed=15"
    ],
    "Mod Slot": [
      "Mod Slot",
      "critical hit chance=6,critical hit damage=12,headshot damage=10,protection from elites=13,armor on kill=18935,status effect resistance=10,pulse resistance=10,incoming repairs=20,skill haste=12,skill duration=10,repair skills=20"
    ],
    "Armor Regen": ["^([a-z\\s]+)\\s+\\d+\\s*-\\s*([\\d.]+)", "$1=$2"],
    "Incoming Repair": [
      "^([a-z\\s]+)\\s+[\\d.]+%?\\s*-\\s*([\\d.]+)%?",
      "$1=$2"
    ],
    "Line Break": ["\\n", ""],
    "Armor Core": ["armour\\s+[\\d,]+\\s*-\\s*([\\d,]+)", "armor=$1"],
    "comma": [",", ""],
    "skill tier": [">\\+(\\d+)<\\s+skill tier", "skill tier=1"],
    "Question ?=0": ["\\?", "0"],
    "Skill Damage": ["skill damage", "skill damage=15"],
    "Skill Haste": ["skill haste", "skill haste=12"],
    "critical chance": ["critical chance", "critical hit chance"],
