---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { META_BUILDS, buildSlug } from '../../../data/build-helpers';

const title = 'Топ Билды — Division 2 мета (TU22.1, 2026)';
const description = 'Лучшие билды Division 2 для TU22.1: St. Elmo Strikers ДД, Iron Lung горение, Tipping Eagle, Большой Алехандро Strikers. Проверенный DPS калькулятор.';
const canonical = 'https://divcalc.xyz/ru/builds/';

const tierColor = { S: '#ef5350', A: '#fdd835', B: '#42a5f5', C: '#888' };
const sorted = [...META_BUILDS].sort((a, b) => {
  const ta = ['S', 'A', 'B', 'C'].indexOf(a.tier || 'C');
  const tb = ['S', 'A', 'B', 'C'].indexOf(b.tier || 'C');
  return ta - tb;
});
---
<BaseLayout {title} {description} {canonical}>
  <main class="catalog-page">
    <nav class="breadcrumb"><a href="/ru/">Главная</a> · <span>Билды</span></nav>
    <h1>Топ Билды ({META_BUILDS.length})</h1>
    <p class="muted">S-tier мета билды, все проверены 1:1 с игрой. Загрузка одной кнопкой в калькулятор.</p>
    <div class="grid">
      {sorted.map(b => (
        <a href={`/builds/${buildSlug(b.id)}`} class="card">
          <div class="card-head">
            {b.tier && <span class="tier" style={`background: ${tierColor[b.tier]}30; color: ${tierColor[b.tier]}; border-color: ${tierColor[b.tier]}80;`}>{b.tier}-Тир</span>}
            {b.weapon_cat && <span class="cat">{b.weapon_cat}</span>}
          </div>
          <h3>{b.name_ru || b.name_en || b.id}</h3>
          {b.tag_ru && <p class="tag">{b.tag_ru}</p>}
          {b.expected_dps_peak_m && <p class="dps">Пик DPS ≈ <strong>{b.expected_dps_peak_m}M</strong></p>}
        </a>
      ))}
    </div>
  </main>
</BaseLayout>

<style>
  .catalog-page { max-width: 1100px; margin: 0 auto; padding: 30px 20px; }
  .breadcrumb { font-size: 12px; color: var(--muted); margin-bottom: 14px; }
  .breadcrumb a { color: var(--muted); }
  h1 { font-size: 30px; margin: 0 0 4px; }
  .muted { color: var(--text-dim); font-size: 13px; margin-bottom: 24px; }
  .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 12px; }
  .card { display: block; padding: 16px; background: var(--bg-2); border: 1px solid var(--border); border-radius: 6px; text-decoration: none; color: var(--text); transition: transform .12s, border-color .12s; }
  .card:hover { transform: translateY(-2px); border-color: rgba(254,175,16,.4); text-decoration: none; }
  .card-head { display: flex; gap: 6px; align-items: center; margin-bottom: 8px; }
  .tier { font-size: 9px; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; padding: 3px 8px; border: 1px solid; border-radius: 3px; }
  .cat { font-size: 9px; color: var(--muted); padding: 3px 7px; background: rgba(255,255,255,.05); border-radius: 3px; letter-spacing: .14em; }
  h3 { font-size: 16px; margin: 6px 0 4px; }
  .tag { font-size: 11px; color: var(--muted); margin: 0 0 8px; }
  .dps { font-size: 13px; color: var(--orange); margin: 0; }
</style>
